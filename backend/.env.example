# ---- Backend (Go API) environment ----

# Postgres connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tasks?sslmode=disable

# Secret used to sign JWTs. MUST be at least 32 characters. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# How long an issued session token stays valid (hours). Default 168 = 7 days.
JWT_TTL_HOURS=168

# Origin of the frontend, used for CORS. No trailing slash.
FRONTEND_ORIGIN=http://localhost:3000

# Port the API listens on.
PORT=8080

# "development" or "production". In production the auth cookie is set with
# Secure + SameSite=None so it works across different frontend/API domains.
APP_ENV=development
